# Auto detect text files and perform LF normalization
* text=auto

# ===========================================================
# Git LFS - Large File Storage
# ===========================================================

# PDF documents
*.pdf filter=lfs diff=lfs merge=lfs -text

# Network capture files
*.pcap filter=lfs diff=lfs merge=lfs -text
*.pcapng filter=lfs diff=lfs merge=lfs -text
*.cap filter=lfs diff=lfs merge=lfs -text

# Large dataset files
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.xls filter=lfs diff=lfs merge=lfs -text

# SQL dumps
*.sql filter=lfs diff=lfs merge=lfs -text

# ML model files
*.pkl filter=lfs diff=lfs merge=lfs -text
*.pickle filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.hdf5 filter=lfs diff=lfs merge=lfs -text
*.onnx filter=lfs diff=lfs merge=lfs -text
*.bin filter=lfs diff=lfs merge=lfs -text

# Numpy/data arrays
*.npy filter=lfs diff=lfs merge=lfs -text
*.npz filter=lfs diff=lfs merge=lfs -text
*.parquet filter=lfs diff=lfs merge=lfs -text
*.feather filter=lfs diff=lfs merge=lfs -text

# Python source files
*.py text eol=lf
*.pyw text eol=lf
*.pyx text eol=lf

# Jupyter Notebooks
*.ipynb text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.conf text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Markup and documentation
*.md text eol=lf
*.rst text eol=lf
*.txt text eol=lf

# Data files
*.csv text eol=lf
*.tsv text eol=lf

# Web files
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf

# Git files
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files - no diff, no merge
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.pkl binary
*.pickle binary
*.npy binary
*.npz binary
*.h5 binary
*.hdf5 binary
*.pt binary
*.pth binary
*.bin binary
*.model binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary

# Jupyter notebook diff (show as text, but use nbdime if available)
*.ipynb diff=jupyternotebook

# Large data files - mark as binary to avoid diff noise
*.parquet binary
*.feather binary

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
